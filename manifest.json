{
  "manifest_version": 3,
  "name": "Stream Pro Speed",
  "version": "2.1",
  "description": "Playback speed control for Hotstar, JioHotstar, Netflix, and Prime Video",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.hotstar.com/*",
    "https://*.jiohotstar.com/*",
    "https://*.netflix.com/*",
    "https://*.primevideo.com/*",
    "https://*.amazon.com/gp/video/*",
    "https://*.amazon.in/gp/video/*",
    "https://*.amazon.co.uk/gp/video/*",
    "https://*.amazon.de/gp/video/*",
    "https://*.amazon.ca/gp/video/*",
    "https://*.amazon.com.au/gp/video/*",
    "https://*.amazon.co.jp/gp/video/*",
    "https://*.amazon.fr/gp/video/*",
    "https://*.amazon.it/gp/video/*",
    "https://*.amazon.es/gp/video/*",
    "https://*.amazon.com.br/gp/video/*",
    "https://*.amazon.com.mx/gp/video/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.hotstar.com/*",
        "https://*.jiohotstar.com/*",
        "https://*.netflix.com/*",
        "https://*.primevideo.com/*",
        "https://*.amazon.com/gp/video/*",
        "https://*.amazon.in/gp/video/*",
        "https://*.amazon.co.uk/gp/video/*",
        "https://*.amazon.de/gp/video/*",
        "https://*.amazon.ca/gp/video/*",
        "https://*.amazon.com.au/gp/video/*",
        "https://*.amazon.co.jp/gp/video/*",
        "https://*.amazon.fr/gp/video/*",
        "https://*.amazon.it/gp/video/*",
        "https://*.amazon.es/gp/video/*",
        "https://*.amazon.com.br/gp/video/*",
        "https://*.amazon.com.mx/gp/video/*"
      ],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Stream Pro Speed",
    "default_icon": "coverpage.png"
  },
  "icons": {
    "128": "coverpage.png"
  }
}
