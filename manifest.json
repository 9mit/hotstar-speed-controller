{
  "manifest_version": 3,
  "name": "Hotstar Pro Speed",
  "version": "2.0",
  "description": "Premium, Live-Aware Playback Assistant for Hotstar and JioHotstar",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.hotstar.com/*",
    "https://*.jiohotstar.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.hotstar.com/*",
        "https://*.jiohotstar.com/*"
      ],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Hotstar Pro Speed",
    "default_icon": "coverpage.png"
  },
  "icons": {
    "128": "coverpage.png"
  }
}
